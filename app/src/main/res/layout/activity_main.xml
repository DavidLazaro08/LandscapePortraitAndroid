<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0014">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/txtCabecera"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRODUCT DETAIL"
            android:textColor="#F2E8FF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/txtSubtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selected game"
            android:textColor="#B84DFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/contenedorProducto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A0830"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/imgProducto"
                android:layout_width="match_parent"
                android:layout_height="230dp"
                android:scaleType="centerCrop"
                android:src="@drawable/neon_streets"
                android:contentDescription="Neon Streets Redux"
                android:layout_marginBottom="14dp" />

            <TextView
                android:id="@+id/txtEtiqueta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● NEW RELEASE"
                android:textColor="#B84DFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NEON STREETS REDUX"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtCategoria"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adventure · SNES"
                android:textColor="#B9A8C9"
                android:textSize="15sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/txtDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="The definitive 16-bit synthwave odyssey with retro arcade vibes."
                android:textColor="#BBBBBB"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/txtPrecio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="€19.99"
                android:textColor="#C84BFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="18dp" />

            <Button
                android:id="@+id/btnComprar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COMPRAR"
                android:textColor="#090012"
                android:backgroundTint="#A020F0" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>